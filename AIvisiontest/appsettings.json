{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information", // 全局最小日志级别（Debug/Information/Warning/Error/Fatal）
      "Override": {
        "Microsoft": "Warning", // 过滤微软类库的日志级别
        "System": "Warning"
      }
    },
    "WriteTo": [
      // 输出到控制台（调试时可见，发布可关闭）
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      // 输出到文件（按日期分割，自动清理）
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt", // 日志文件路径（生成如 log-20260304.txt）
          "rollingInterval": "Day", // 按天分割日志
          "retainedFileCountLimit": 7, // 保留7天日志（自动删除更早的）
          "fileSizeLimitBytes": 10485760, // 单个文件最大10MB（可选）
          "rollOnFileSizeLimit": true, // 超过大小自动新建文件（可选）
          "encoding": "utf-8",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext", // 支持日志上下文（如添加模块名）
      "WithMachineName", // 附加机器名（多机部署有用）
      "WithThreadId" // 附加线程ID（调试多线程问题）
    ],
    "Properties": {
      "Application": "YourPrismApp" // 全局属性（标识应用名）
    }
  }

}
